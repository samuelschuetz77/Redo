<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedoRepository_Sam_Paula.Views.NewScenarioPage"
             Title="New Scenario">

    <VerticalStackLayout Spacing="12" Padding="16">

        <Entry Placeholder="Loan Amount" Keyboard="Numeric"
               Text="{Binding LoanAmountText}" />

        <Entry Placeholder="Interest Rate (%)" Keyboard="Numeric"
               Text="{Binding InterestRateText}" />

        <Entry Placeholder="Term (years)" Keyboard="Numeric"
               Text="{Binding LoanTermYearsText}" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}" />

        <Label Text="{Binding MonthlyPayment, StringFormat='Monthly: {0:C}'}" />
        <Label Text="{Binding TotalPaid, StringFormat='Total Paid: {0:C}'}" />
        <Label Text="{Binding TotalInterestPaid, StringFormat='Total Interest: {0:C}'}" />

        <Button Text="Save Scenario"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding CanSave}" />

    </VerticalStackLayout>
</ContentPage>
